# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must be LF
*.sh text eol=lf

# YAML files must be LF (critical for Render deployment)
*.yaml text eol=lf
*.yml text eol=lf

# Python files
*.py text eol=lf

# JavaScript/JSX files
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Procfile must be LF
Procfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.rar binary

# Django migrations
*.pyc binary

